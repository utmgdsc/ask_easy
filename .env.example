# Database
# For Docker Compose: use "postgres" as host (service name)
# For pnpm dev (native): use "localhost"
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ask_easy
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ask_easy

# Redis
# For Docker Compose: use "redis" as host (service name)
# For pnpm dev (native): use "localhost"
REDIS_URL=redis://redis:6379

# Session (iron-session)
# Generate with: openssl rand -hex 32
# Must be at least 32 characters. Keep this secret — it signs all session cookies.
SESSION_SECRET=replace-me-with-a-32-plus-char-random-string

# Development auth (ignored in production)
# Set this to any UTORid string to simulate a logged-in user locally.
# In production, Apache + mod_shib injects the real utorid header instead.
DEV_UTORID=testuser
DEV_NAME=Test User
DEV_EMAIL=testuser@mail.utoronto.ca
# Override role in dev without editing whitelist.txt (STUDENT | TA | PROFESSOR)
DEV_ROLE=STUDENT

# Whitelist
# Path to the instructor whitelist file (relative to the project root).
# Default: ./whitelist.txt
# WHITELIST_PATH=./whitelist.txt
